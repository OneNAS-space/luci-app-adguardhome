#!/bin/sh /etc/rc.common
#
# SPDX-License-Identifier: GPL-2.0-only
#
# shellcheck disable=SC3043 # ash supports local

# matches dnsmasq
START=19
# stops before networking stops
STOP=89

PROG=/usr/bin/AdGuardHome
USE_PROCD=1

# 额外拓展指令集
EXTRA_COMMANDS="do_redirect force_reload isrunning"
EXTRA_HELP="\
\tdo_redirect \t0 or 1\n\
\tforce_reload\n\
\tisrunning"

CONTROL_SCRIPT="/usr/share/AdGuardHome/control.sh"
CRON_FILE=/etc/crontabs/root

# 用于下发密码和修改端口的辅助函数
config_editor() {
	awk -v yaml="$1" -v value="$2" -v file="$3" -v ro="$4" '
	BEGIN{split(yaml,part,"\.");s="";i=1;l=length(part);}
	{
		if (match($0,s""part[i]":")) {
			if (i==l) {
				split($0,t,": ");
				if (ro==""){
					system("sed -i '\''"FNR"c\\" t[1] ": " value "'\'' " file " >/dev/null 2>&1");
				} else {
					print(t[2]);
				}
				exit;
			}
			s=s"[- ]{2}";
			i++;
		}
	}' "$3"
}

# 时区提取函数，确保沙箱容器内时间对齐
get_tz() {
	SET_TZ=""
	local zonename
	zonename="$(uci get system.@system[0].zonename 2>/dev/null)"
	if [ -n "$zonename" ]; then
		SET_TZ="$zonename"
		return
	fi
	for tzfile in /etc/TZ /var/etc/TZ; do
		[ -e "$tzfile" ] && tz="$(cat "$tzfile" 2>/dev/null)" && break
	done
	[ -n "$tz" ] && SET_TZ=$tz && return
}

# 计划任务接管管道
do_crontab() {
	local enabled="$1"
	local crontab="$2"
	local findstr default cronenable cronreload=0

	findstr="/usr/share/AdGuardHome/update_core.sh"
	default="30 3 * * * /usr/share/AdGuardHome/update_core.sh 2>&1"
	[ "$enabled" = "0" ] || [ "${crontab//autoupdate/}" = "$crontab" ] && cronenable=0 || cronenable=1
	crontab_editor

	[ "$cronreload" -gt 0 ] && /etc/init.d/cron restart
}

crontab_editor() {
	local line
	line="$(grep "$findstr" $CRON_FILE 2>/dev/null)"
	if [ "${line:0:1}" != "#" ]; then
		if [ "$cronenable" -eq 1 ]; then
			if [ -z "$line" ]; then
				echo "$default" >> $CRON_FILE
				cronreload=$((cronreload+1))
			fi
		elif [ -n "$line" ]; then
			sed -i "\,$findstr,d" $CRON_FILE
			echo "#$line" >> $CRON_FILE
			cronreload=$((cronreload+1))
		fi
	else
		if [ "$cronenable" -eq 1 ]; then
			sed -i "\,$findstr,d" $CRON_FILE
			echo "${line:1}" >> $CRON_FILE
			cronreload=$((cronreload+1))
		fi
	fi
}

boot() {
	ADGUARDHOME_BOOT=1
	start "$@"
}

start_service() {
	if [ -n "$ADGUARDHOME_BOOT" ]; then
		# Do not start yet, wait for triggers
		return 0
	fi

	rm -f /var/run/AdGserverdis 2>/dev/null
	config_load 'adguardhome'

	local config_name='config'
	local config_file config group user verbose work_dir workdir
	local gc maxprocs memlimit
	local enabled hashpass crontab redirect

	uci_validate_section 'adguardhome' 'adguardhome' "$config_name" \
		'gc:uinteger:0' \
		'group:string:adguardhome' \
		'config:string' \
		'config_file:string:/etc/adguardhome/adguardhome.yaml' \
		'jail_mount:list(string)' \
		'jail_mount_rw:list(string)' \
		'maxprocs:uinteger:0' \
		'memlimit:uinteger:0' \
		'user:string:adguardhome' \
		'verbose:bool:0' \
		'workdir:string' \
		'work_dir:string:/var/lib/adguardhome' \
		'enabled:bool:0' \
		'hashpass:string' \
		'crontab:string' \
		'redirect:string:none'

	# Compatibility with older configs
	[ -n "$config" ] && config_file="$config"
	[ -n "$workdir" ] && work_dir="$workdir"

	# 处理 hashpass 明文下发及回刷清除
	if [ -n "$hashpass" ]; then
		config_editor "users.password" "$hashpass" "$config_file"
		uci set adguardhome."$config_name".hashpass=""
		uci commit adguardhome
	fi

	# 下发计划任务变更
	do_crontab "$enabled" "$crontab"

	# 未启用则联动清理重定向防火墙规则并安全退出
	if [ "$enabled" = 0 ]; then
		$CONTROL_SCRIPT 0
		return 0
	fi

	local config_dir
	config_dir=$(dirname "$config_file")
	if [ "$config_dir" = '/etc' ]; then
		echo 'AdGuard Home config must be stored in its own directory, and not in /etc' >&2
		return 1
	fi
	mkdir -m 0700 -p "$config_dir"
	chown -R "$user":"$group" "$config_dir"

	mkdir -m 0700 -p "$work_dir"
	chown -R "$user":"$group" "$work_dir"

	# 核心缺失时静默降级并呼叫核心下载脚本
	if [ ! -f "$PROG" ]; then
		$CONTROL_SCRIPT 0
		/usr/share/AdGuardHome/update_core.sh >/tmp/AdGuardHome_update.log 2>&1 &
		return 0
	fi

	procd_open_instance adguardhome

	procd_set_param command "$PROG"

	[ "$gc" -le 0 ] || procd_append_param env GOGC="$gc"
	[ "$maxprocs" -le 0 ] || procd_append_param env GOMAXPROCS="$maxprocs"
	[ "$memlimit" -le 0 ] || procd_append_param env GOMEMLIMIT="$memlimit"

	# 为隔离沙箱装载精确的时区环境变量
	local SET_TZ
	get_tz
	[ -n "$SET_TZ" ] && procd_append_param env TZ="$SET_TZ"

	procd_append_param command --config "$config_file"
	procd_append_param command --logfile syslog
	# procd_append_param command --no-check-update
	[ "$verbose" = 1 ] && procd_append_param command --verbose
	procd_append_param command --work-dir "$work_dir"

	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param user "$user"
	procd_set_param group "$group"
	procd_set_param capabilities '/etc/capabilities/adguardhome.json'
	procd_set_param no_new_privs 1
	procd_set_param respawn

	# log is needed for logging to syslog instead of stdout
	# procfs is needed to readlink /proc/self/exe
	procd_add_jail adguardhome log procfs

	# config directory must be writable to write new config files
	procd_add_jail_mount_rw "$config_dir"
	procd_add_jail_mount_rw "$work_dir"

	procd_add_jail_mount '/etc/hosts'
	procd_add_jail_mount '/etc/ssl/certs'
	[ -f /etc/TZ ] && procd_add_jail_mount '/etc/TZ'

	config_list_foreach "$config_name" jail_mount procd_add_jail_mount
	config_list_foreach "$config_name" jail_mount_rw procd_add_jail_mount_rw

	procd_close_instance

	# 主进程成功提交启动后，开始异步介入接管控制
	if [ -f "$config_file" ]; then
		($CONTROL_SCRIPT 1) &
	else
		$CONTROL_SCRIPT 0
		if [ "$redirect" != "none" ]; then
			procd_open_instance "waitconfig"
			procd_set_param command "/usr/share/AdGuardHome/watchconfig.sh"
			procd_close_instance
		fi
	fi

	# 10秒看门狗防护：如果主进程异常崩塌，自动熔断重定向，避免全网断网
	(sleep 10 && [ -z "$(pgrep -f "$(basename "$PROG")")" ] && logger -t adguardhome "no process in 10s cancel redirect" && $CONTROL_SCRIPT 0 ) &
}

# 必须注入显式的服务中止钩子，用于平滑清理 nft 规则和 crontab
stop_service() {
	config_load 'adguardhome'
	local config_name='config'
	local crontab
	config_get crontab "$config_name" crontab ""

	$CONTROL_SCRIPT 0
	do_crontab 0 "$crontab"
	touch /var/run/AdGserverdis
}

do_redirect() {
	$CONTROL_SCRIPT "$1"
}

_isrunning() {
	[ ! -f "$PROG" ] && return 2
	pgrep -f "$(basename "$PROG")" >/dev/null 2>&1 && return 0
	return 1
}

isrunning() {
	_isrunning
	local r=$?
	[ "$r" = "0" ] && echo "running" || ([ "$r" = "1" ] && echo "not run" || echo "no bin")
	return $r
}

force_reload() {
	_isrunning && procd_send_signal adguardhome || start
}

service_triggers() {
	procd_add_reload_trigger adguardhome

	if [ -n "$ADGUARDHOME_BOOT" ]; then
		# Wait for interfaces to be up before starting AdGuard Home for real.
		# Prevents issues like https://github.com/openwrt/packages/issues/21868.
		procd_add_raw_trigger 'interface.*.up' 5000 /etc/init.d/adguardhome restart
	fi
}
